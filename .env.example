# LLM 后端选择：trae | openai | custom（默认 trae，无需自备 API_KEY）
LLM_BACKEND=trae

# TRAE 内置模型配置（默认值，通常无需修改）
TRAE_BASE_URL=https://api.trae.cn/v1
TRAE_MODEL=trae-model
TRAE_API_KEY=

# OpenAI 兼容后端（LLM_BACKEND=openai 时使用）
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini

# 自定义后端（LLM_BACKEND=custom 时使用，需自定义 BASE_URL / API_KEY / MODEL）
# CUSTOM_BASE_URL=...
# CUSTOM_API_KEY=...
# CUSTOM_MODEL=...
